{
  "name": "local-coding-agent",
  "version": "5.0.0-pro",
  "private": true,
  "type": "module",
  "main": "server.mjs",
  "description": "Local MCP server that lets ChatGPT Web work with files and commands on your own machine.",
  "author": "Lương Duy",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/luongduy2798/local-coding-agent.git"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node server.mjs",
    "test": "npm run test:architecture && npm run test:safety && npm run test:runtime && npm run test:changes && npm run test:agent && npm run test:pro && npm run test:performance && npm run test:hardening && npm run test:figma && npm run test:security",
    "test:architecture": "node scripts/check-architecture.mjs",
    "test:safety:scan": "node scripts/check-test-safety.mjs",
    "test:guard": "node tests/test-guard.test.mjs",
    "test:safety": "npm run test:safety:scan && npm run test:guard",
    "test:changes": "node tests/integration/change-journal.test.mjs",
    "test:agent:inner": "node tests/integration/agent.test.mjs",
    "test:agent": "node tests/runners/run-agent-isolated.mjs",
    "test:security:inner": "node tests/security/runtime.test.mjs",
    "test:security:baseline:inner": "node tests/security/baseline.test.mjs",
    "test:security": "node tests/runners/run-security-isolated.mjs",
    "test:hardening": "node tests/integration/hardening.test.mjs",
    "test:pro": "node tests/integration/pro.test.mjs",
    "test:performance": "node tests/integration/performance.test.mjs",
    "test:runtime:session": "node tests/integration/mcp-session.test.mjs",
    "test:runtime:catalog": "node tests/integration/runtime-catalog.test.mjs",
    "test:runtime:audit": "node tests/unit/audit-activity.test.mjs && node tests/unit/audit-rotation.test.mjs",
    "test:runtime:policy": "node tests/integration/policy-contract.test.mjs",
    "test:runtime:storage": "node tests/integration/storage-registry.test.mjs && node --test tests/unit/runtime-data-migration.test.mjs",
    "test:runtime:lifecycle": "node tests/integration/workspace-lifecycle.test.mjs && node tests/integration/archived-change-routes.test.mjs && node ../scripts/workspace-lifecycle-cli.test.mjs",
    "test:runtime:multiworkspace": "node --test tests/integration/multi-workspace.test.mjs",
    "test:runtime:patch": "node tests/integration/patch-transaction.test.mjs",
    "test:runtime:task": "node --test tests/unit/task-router.test.mjs",
    "test:runtime:task-close": "node tests/integration/task-close-guard.test.mjs",
    "test:runtime:review": "node --test tests/integration/review-diff.test.mjs",
    "test:runtime:non-git": "node --test tests/integration/non-git-mutation.test.mjs",
    "test:runtime:reconnect": "node --test tests/integration/reconnect-restart.test.mjs",
    "test:runtime:intelligence": "node --test tests/unit/coding-intelligence.test.mjs tests/unit/typescript-semantic-adapter.test.mjs tests/unit/workspace-graph-builder.test.mjs",
    "test:runtime": "npm run test:runtime:session && npm run test:runtime:catalog && npm run test:runtime:audit && npm run test:runtime:policy && npm run test:runtime:storage && npm run test:runtime:lifecycle && npm run test:runtime:task && npm run test:runtime:multiworkspace && npm run test:runtime:patch && npm run test:runtime:task-close && npm run test:runtime:review && npm run test:runtime:non-git && npm run test:runtime:reconnect && npm run test:runtime:intelligence",
    "eval": "node ../evals/run.mjs && node ../evals/tool-selection.mjs",
    "bench:runtime": "node --expose-gc benchmarks/scale.mjs --scale=10k",
    "bench:runtime:cold": "node --expose-gc benchmarks/scale.mjs --scale=10k --cold-builder",
    "bench:runtime:scale": "node --expose-gc benchmarks/scale.mjs --scale=10k --cold-builder && node --expose-gc benchmarks/scale.mjs --scale=100k --allow-large --cold-builder && node --expose-gc benchmarks/scale.mjs --scale=250k --allow-large --cold-builder",
    "bench:runtime:reconnect": "node benchmarks/reconnect-stress.mjs --cycles=1000",
    "test:figma": "node tests/integration/figma-desktop.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^3.25.76"
  }
}
