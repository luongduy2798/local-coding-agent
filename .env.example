CONTROL_PLANE_TUNNEL_ID=tunnel_...
CONTROL_PLANE_API_KEY=sk-proj-...

# Trusted-local defaults. Safe/balanced remain selectable in setup/TUI.
AGENT_ACCESS_MODE=full
AGENT_MODE=full
AGENT_POLICY=full
AGENT_WORKFLOW_MODE=auto
# auto | required | off. Ignored by full mode, which always runs directly.
AGENT_OS_SANDBOX=auto

# Verification is explicit-only: LCA will not run tests/build/lint unless the
# prompt, Plan card, dashboard button, or an explicitly configured hook asks it.
# Official Figma Desktop MCP bridge. No OAuth app, client ID, or Figma token is required.
FIGMA_DESKTOP_MCP_URL=http://127.0.0.1:3845/mcp
FIGMA_DESKTOP_TIMEOUT_MS=30000
