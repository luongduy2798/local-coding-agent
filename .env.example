CONTROL_PLANE_TUNNEL_ID=tunnel_...
CONTROL_PLANE_API_KEY=sk-proj-...

# Optional runtime data root. Tests must always override this with an isolated temp directory.
# AGENT_DATA_DIR=/absolute/path/to/lca-data

# Maximum text snapshot size for Review Changes. Default: 5 MiB.
AGENT_MAX_SNAPSHOT_BYTES=5242880

# Official Figma Desktop MCP bridge. No OAuth app, client ID, or Figma token is required.
FIGMA_DESKTOP_MCP_URL=http://127.0.0.1:3845/mcp
FIGMA_DESKTOP_TIMEOUT_MS=30000
